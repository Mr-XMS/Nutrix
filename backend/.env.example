# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nutrix?schema=public"

# JWT
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-change-in-production"

# App
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Redis (for rate limiting & session store)
REDIS_URL="redis://localhost:6379"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_STARTER_PRICE_ID="price_..."
STRIPE_PRO_PRICE_ID="price_..."
STRIPE_ENTERPRISE_PRICE_ID="price_..."

# Email (SendGrid)
SENDGRID_API_KEY="SG...."
SENDGRID_FROM_EMAIL="noreply@nutrix.com.au"

# S3/R2 (file uploads)
S3_BUCKET="nutrix-uploads"
S3_REGION="ap-southeast-2"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
